# Leave QWEN_API_KEY unset to run entirely in mock mode (no network calls, deterministic
# stand-in responses) -- useful for building/demoing before hackathon credits arrive.
QWEN_API_KEY=
# Qwen Cloud's OpenAI-compatible endpoint (international DashScope). Only used when
# QWEN_API_KEY is set. Source: https://docs.qwencloud.com/developer-guides/getting-started/first-api-call
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model tiering: cheap/fast model for bidding, stronger model for negotiation + LLM-judge scoring.
# See https://docs.qwencloud.com/developer-guides/getting-started/model-selection
QWEN_MODEL_BID=qwen3.6-flash
QWEN_MODEL_NEGOTIATE=qwen3.7-plus
QWEN_MODEL_JUDGE=qwen3.7-max
QWEN_MODEL_BASELINE=qwen3.7-plus

# Coordinator tuning. Allocation ranks specialists by confidence; a runner-up bid within
# this many confidence points (not a percentage) of the top bid is treated as a genuine
# rival and triggers negotiation instead of an outright win.
CONFLICT_CONFIDENCE_THRESHOLD=0.10
NEGOTIATION_MAX_ROUNDS=3

HOST=0.0.0.0
PORT=8000
