# Leave QWEN_API_KEY unset to run entirely in mock mode (no network calls, deterministic
# stand-in responses) -- useful for building/demoing before hackathon credits arrive.
QWEN_API_KEY=
# Qwen Cloud's OpenAI-compatible endpoint (international DashScope). Only used when
# QWEN_API_KEY is set. Source: https://docs.qwencloud.com/developer-guides/getting-started/first-api-call
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model tiering: cheap/fast model for bidding, stronger model for negotiation + LLM-judge scoring.
# See https://docs.qwencloud.com/developer-guides/getting-started/model-selection
QWEN_MODEL_BID=qwen3.6-flash
QWEN_MODEL_NEGOTIATE=qwen3.7-plus
QWEN_MODEL_JUDGE=qwen3.7-max
QWEN_MODEL_BASELINE=qwen3.7-plus

# Coordinator tuning. Allocation ranks specialists by confidence; a runner-up bid within
# this many confidence points (not a percentage) of the top bid, AND with at least
# CONTESTED_CONFIDENCE_FLOOR confidence itself, is treated as a genuine rival and triggers
# negotiation instead of an outright win. The floor exists because a numerically-close but
# low-confidence rival can be noise, not a real dispute (observed directly: an unambiguous
# case that normally wins outright at ~0.95 spuriously escalated on one real run).
CONFLICT_CONFIDENCE_THRESHOLD=0.10
CONTESTED_CONFIDENCE_FLOOR=0.4

# 2 = round 1 claims + one round of rebuttal, then judge. A second rebuttal round was
# measured (twice, in real transcripts) to degrade already-good round-2 consensus into
# unsupported speculation, forced into existence just to have something new to rebut --
# not genuine new disagreement. Raise only if a specific incident type is shown to need it.
NEGOTIATION_MAX_ROUNDS=2

# How many independent judge samples to majority-vote across on a contested case (self-
# consistency). 5, not 3 -- genuinely close calls (e.g. two specialists with real, distinct,
# conflicting evidence) were still measured to land on the wrong side often enough at 3
# votes across repeated real runs; more samples means a more reliable majority.
JUDGE_VOTES=5

# How many of the incident's monitoring tools the baseline agent may check before it must
# commit to an answer -- simulates a real generalist's time pressure during a live incident.
BASELINE_TOOL_BUDGET=2

HOST=0.0.0.0
PORT=8000
